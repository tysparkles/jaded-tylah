---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Work With Us — TylahJadeArt">
  <nav class="fixed top-0 left-0 right-0 z-50 px-8 py-6 flex justify-between items-center bg-jaded-bg/80 backdrop-blur-md border-b border-white/5">
    <a href="/" class="flex items-center gap-3">
      <img src="/favicon.svg" alt="Dragon" class="w-10 h-10" />
      <span class="text-xl font-display font-bold tracking-tight">
        <span class="text-dusty-pink">JADED</span>
        <span class="text-muted-sage"> × </span>
        <span class="text-cream">TylahJade</span>
      </span>
    </a>
    <div class="flex gap-8 text-sm text-muted-silver">
      <a href="/design" class="hover:text-moss-green transition-colors">Design</a>
      <a href="/art" class="text-moss-green">Art</a>
    </div>
  </nav>

  <main>
    <section class="min-h-[60vh] flex items-center px-6 pt-32 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-art-bg via-charcoal to-art-surface/50"></div>
      <div class="absolute w-80 h-80 bg-moss-green/5 rounded-full blur-3xl top-20 right-20"></div>

      <div class="max-w-4xl relative z-10">
        <p class="text-moss-green text-xs tracking-[0.3em] uppercase mb-6">Let's Create Together</p>
        <h1 class="text-5xl md:text-6xl font-display font-bold mb-8 leading-tight">
          <span class="text-cream">Work</span>
          <span class="text-moss-green"> With Me</span>
        </h1>
        <p class="text-muted-silver text-xl max-w-2xl leading-relaxed">
          Own a piece, commission a painting, or collaborate on something unique. Every creative relationship starts with a conversation.
        </p>
      </div>
    </section>

    <!-- What I Offer -->
    <section class="py-24 px-6 border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-xs tracking-[0.3em] text-cream/40 uppercase mb-12">What I Offer</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            {
              title: 'Original Paintings',
              price: 'From $300',
              desc: 'Acrylic and mixed media on canvas. Each piece is one-of-a-kind, created with layered textures and emotional depth.',
              includes: ['Sizes 8×10" to 24×36"', 'Certificate of authenticity', 'Care instructions', 'Local delivery available']
            },
            {
              title: 'Commission a Painting',
              price: 'From $800',
              desc: 'A custom piece created just for you or your space. Share your vision, color preferences, and the feeling you want — I\'ll bring it to life.',
              includes: ['Personal consultation', 'Progress updates', 'One revision included', 'Gift wrapping available']
            },
            {
              title: 'Murals & Installations',
              price: 'Contact for quote',
              desc: 'Large-scale wall art for homes, studios, businesses, and events. Transform any space with custom painted work.',
              includes: ['Site visit or photos', 'Design mockup', 'Professional finish', 'Materials included']
            },
          ].map((pkg) => (
            <div class="p-8 bg-art-surface/50 border border-moss-green/10 rounded-2xl">
              <h3 class="font-display text-xl font-bold mb-2">{pkg.title}</h3>
              <p class="text-moss-green text-sm font-medium mb-4">{pkg.price}</p>
              <p class="text-muted-silver text-sm leading-relaxed mb-6">{pkg.desc}</p>
              <ul class="space-y-2">
                {pkg.includes.map((item) => (
                  <li class="text-sm text-cream/60 flex items-center gap-2">
                    <span class="text-moss-green">✓</span> {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="py-24 px-6 bg-art-surface/30">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-xs tracking-[0.3em] text-cream/40 uppercase mb-12">The Process</h2>
        <div class="space-y-8">
          {[
            { step: '01', title: 'Reach Out', desc: 'Tell me what you\'re looking for — an existing piece, a commission, or something you\'ve been dreaming about. No pressure, just a conversation.' },
            { step: '02', title: 'We Connect', desc: 'We\'ll chat about your vision, your space, your colors, and the feeling you want. I might ask about the memory or emotion driving this — it helps.' },
            { step: '03', title: 'I Create', desc: 'I get to work. For commissions, I\'ll share progress updates along the way so you can see the piece come to life.' },
            { step: '04', title: 'It\'s Yours', desc: 'Once it\'s done and you love it, it ships or gets delivered. Every piece comes with care instructions and a little note from me.' },
          ].map((item) => (
            <div class="flex gap-6 items-start p-6 bg-white/5 rounded-xl">
              <span class="text-moss-green font-display text-3xl font-bold opacity-60">{item.step}</span>
              <div>
                <h3 class="font-display text-xl font-bold mb-2">{item.title}</h3>
                <p class="text-muted-silver text-sm leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact Form -->
    <section class="py-24 px-6 border-t border-white/5">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-xs tracking-[0.3em] text-cream/40 uppercase mb-4 text-center">Start the Conversation</h2>
        <p class="text-muted-silver text-center mb-12">Interested in a piece or have a project in mind? I'd love to hear from you.</p>

        <form class="space-y-6" action="#" method="POST">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="text-xs text-cream/60 uppercase tracking-wider mb-2 block">Name</label>
              <input type="text" name="name" required class="w-full px-4 py-3 bg-art-surface border border-white/10 rounded-xl text-cream placeholder-muted-silver focus:border-moss-green/50 focus:outline-none transition-colors" placeholder="Your name" />
            </div>
            <div>
              <label class="text-xs text-cream/60 uppercase tracking-wider mb-2 block">Email</label>
              <input type="email" name="email" required class="w-full px-4 py-3 bg-art-surface border border-white/10 rounded-xl text-cream placeholder-muted-silver focus:border-moss-green/50 focus:outline-none transition-colors" placeholder="your@email.com" />
            </div>
          </div>
          <div>
            <label class="text-xs text-cream/60 uppercase tracking-wider mb-2 block">Interested In</label>
            <select name="interest" class="w-full px-4 py-3 bg-art-surface border border-white/10 rounded-xl text-cream focus:border-moss-green/50 focus:outline-none transition-colors">
              <option value="" class="text-charcoal">Select an option</option>
              <option value="original" class="text-charcoal">Buying an Original Painting</option>
              <option value="commission" class="text-charcoal">Commissioning a Painting</option>
              <option value="mural" class="text-charcoal">Mural or Wall Art</option>
              <option value="pottery" class="text-charcoal">Pottery or Ceramics</option>
              <option value="collaboration" class="text-charcoal">Collaboration or Project</option>
              <option value="other" class="text-charcoal">Something else</option>
            </select>
          </div>
          <div>
            <label class="text-xs text-cream/60 uppercase tracking-wider mb-2 block">Budget Range</label>
            <select name="budget" class="w-full px-4 py-3 bg-art-surface border border-white/10 rounded-xl text-cream focus:border-moss-green/50 focus:outline-none transition-colors">
              <option value="" class="text-charcoal">Select a range</option>
              <option value="under-500" class="text-charcoal">Under $500</option>
              <option value="500-1k" class="text-charcoal">$500 - $1,000</option>
              <option value="1k-2k" class="text-charcoal">$1,000 - $2,000</option>
              <option value="2k-5k" class="text-charcoal">$2,000 - $5,000</option>
              <option value="5k+" class="text-charcoal">$5,000+ (Mural/Big project)</option>
            </select>
          </div>
          <div>
            <label class="text-xs text-cream/60 uppercase tracking-wider mb-2 block">Tell me about your vision</label>
            <textarea name="message" rows="5" required class="w-full px-4 py-3 bg-art-surface border border-white/10 rounded-xl text-cream placeholder-muted-silver focus:border-moss-green/50 focus:outline-none transition-colors resize-none" placeholder="What are you envisioning? Any colors, moods, or memories you want the piece to carry?"></textarea>
          </div>
          <button type="submit" class="w-full px-8 py-4 bg-gradient-to-r from-moss-green to-dusty-pink text-charcoal font-medium rounded-xl hover:opacity-90 transition-all">
            Send Message
          </button>
          <p class="text-xs text-muted-silver text-center">I respond to every message — usually within 48 hours.</p>
        </form>
      </div>
    </section>

    <footer class="py-12 px-6 border-t border-white/5">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-3">
          <img src="/favicon.svg" alt="Dragon" class="w-6 h-6" />
          <span class="text-sm text-muted-silver">
            <span class="text-dusty-pink">JADED</span>
            <span class="text-muted-sage"> × </span>
            <span class="text-cream">TylahJade</span>
          </span>
        </div>
        <p class="text-muted-silver text-xs">© 2025 TylahJadeArt. All rights reserved.</p>
        <div class="flex gap-6 text-xs text-muted-silver">
          <a href="/art" class="hover:text-moss-green transition-colors">Gallery</a>
          <a href="/art/about" class="hover:text-moss-green transition-colors">About</a>
          <a href="/art/work-with-us" class="hover:text-moss-green transition-colors">Inquire</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>