---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="TylahJadeArt — Paintings, Murals, Mixed Media">
  <nav class="fixed top-0 left-0 right-0 z-50 px-8 py-6 flex justify-between items-center bg-jaded-bg/80 backdrop-blur-md border-b border-white/5">
    <a href="/" class="text-xl font-display font-bold tracking-tight">
      <span class="text-dusty-pink">JADED</span>
      <span class="text-muted-sage"> × </span>
      <span class="text-cream">TylahJade</span>
    </a>
    <div class="flex gap-8 text-sm text-muted-silver">
      <a href="/design" class="hover:text-dusty-pink transition-colors">Design</a>
      <a href="/art" class="text-moss-green">Art</a>
    </div>
  </nav>

  <main class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <span class="text-moss-green text-xs tracking-[0.3em] uppercase">The tactile, emotional side</span>
      <h1 class="text-5xl font-display font-bold mt-4 mb-6">TylahJadeArt</h1>
      <p class="text-muted-silver text-lg mb-12 max-w-2xl">
        Playful. Painterly. Expressive. A world of paintings, murals, pottery, and mixed media that feels touched by human hands and alive with texture.
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        {['Paintings', 'Murals', 'Pottery', 'Sketchbooks', 'Photography', 'Mixed Media'].map((item) => (
          <div class="p-8 bg-art-surface border border-moss-green/20 rounded-xl hover:border-moss-green/50 transition-all group cursor-pointer">
            <h3 class="font-display text-xl group-hover:text-moss-green transition-colors">{item}</h3>
            <p class="text-muted-silver text-sm mt-2">View works →</p>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>