---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Design', href: '/design', accent: 'jaded' },
  { label: 'Art', href: '/art', accent: 'art' },
  { label: 'About', href: '/about' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 glass border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-dusty-pink to-muted-sage flex items-center justify-center">
          <span class="font-display font-bold text-charcoal text-lg">J</span>
        </div>
        <span class="font-display text-sm tracking-wide text-cream/80 group-hover:text-cream transition-colors">
          JADED<span class="text-dusty-pink">×</span>TYLAHJADE
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="relative text-sm tracking-wide transition-colors hover:text-cream"
            class:list={[
              item.accent === 'jaded' && 'text-muted-sage hover:text-muted-sage/80',
              item.accent === 'art' && 'text-dusty-pink hover:text-dusty-pink/80',
              !item.accent && 'text-cream/70',
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Mobile menu button -->
      <button id="menu-toggle" class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5">
        <span class="w-6 h-0.5 bg-cream/70 transition-all origin-center"></span>
        <span class="w-6 h-0.5 bg-cream/70 transition-all"></span>
        <span class="w-4 h-0.5 bg-cream/50 transition-all"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-white/5 bg-charcoal/95 backdrop-blur-xl">
    <div class="px-6 py-4 space-y-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block text-sm tracking-wide text-cream/70 hover:text-cream transition-colors"
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>