---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Animated gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-jaded-bg via-charcoal to-art-bg"></div>

  <!-- Floating orbs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-dusty-pink/10 blur-3xl animate-float"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full bg-muted-sage/10 blur-3xl animate-float" style="animation-delay: -3s;"></div>

  <!-- Dragon symbol watermark -->
  <div class="absolute inset-0 flex items-center justify-center opacity-[0.02]">
    <svg viewBox="0 0 200 200" class="w-[800px] h-[800px]" fill="currentColor">
      <path d="M100 10 L120 60 L180 50 L140 90 L180 130 L120 120 L100 180 L80 120 L20 130 L60 90 L20 50 L80 60 Z" />
    </svg>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <!-- Eyebrow -->
    <p class="text-dusty-pink/80 text-sm tracking-[0.3em] uppercase mb-6 animate-pulse-glow">
      Digital Worlds · Physical Textures
    </p>

    <!-- Main heading -->
    <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold mb-8 leading-[0.9]">
      <span class="block text-cream">Design.</span>
      <span class="block text-gradient">Art.</span>
      <span class="block text-cream/80">Story.</span>
    </h1>

    <!-- Subheading -->
    <p class="text-cream/50 text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
      Multidisciplinary creator working at the intersection of digital precision and physical artistry. Two hemispheres of the same creative mind.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/design"
        class="group px-8 py-4 bg-muted-sage text-charcoal font-medium rounded-full hover:bg-muted-sage/90 transition-all flex items-center gap-2"
      >
        <span>Explore Design</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="/art"
        class="group px-8 py-4 border border-dusty-pink/30 text-dusty-pink font-medium rounded-full hover:bg-dusty-pink/10 transition-all flex items-center gap-2"
      >
        <span>Explore Art</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-cream/30">
      <span class="text-xs tracking-widest uppercase">Scroll</span>
      <div class="w-px h-12 bg-gradient-to-b from-cream/30 to-transparent"></div>
    </div>
  </div>
</section>