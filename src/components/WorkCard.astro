---
interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  accent: 'jaded' | 'art';
}

const { title, description, href, image, accent } = Astro.props;
---

<a
  href={href}
  class="group block rounded-2xl overflow-hidden hover-lift"
>
  <div
    class="aspect-[4/3] bg-cover bg-center relative"
    class:list={[
      'after:absolute after:inset-0 after:bg-gradient-to-t after:from-black/60 after:to-transparent',
      accent === 'jaded' && 'bg-jaded-surface',
      accent === 'art' && 'bg-art-surface',
    ]}
    style={image ? `background-image: url(${image})` : undefined}
  >
    {!image && (
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center">
          <span class="text-cream/20 text-2xl">+</span>
        </div>
      </div>
    )}
  </div>

  <div class="p-6 -mt-12 relative z-10">
    <h3
      class="font-display text-lg font-medium mb-1"
      class:list={[
        accent === 'jaded' && 'text-muted-sage',
        accent === 'art' && 'text-dusty-pink',
      ]}
    >
      {title}
    </h3>
    <p class="text-sm text-cream/50">{description}</p>
  </div>
</a>