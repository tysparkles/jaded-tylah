---
---

<section class="py-32 px-6 border-y border-white/5">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20">
      <p class="text-sm tracking-[0.2em] text-cream/40 uppercase mb-4">Choose Your World</p>
      <h2 class="font-display text-3xl md:text-5xl font-bold text-cream">Two Wings. One Mind.</h2>
    </div>

    <!-- Split cards -->
    <div class="grid md:grid-cols-2 gap-8">
      <!-- JADED DESIGN -->
      <a
        href="/design"
        class="group relative overflow-hidden rounded-3xl aspect-[4/5] bg-jaded-surface border border-white/5 hover:border-muted-sage/30 transition-all duration-500"
      >
        <!-- Background pattern -->
        <div class="absolute inset-0 opacity-10">
          <div class="absolute inset-0" style="background-image: linear-gradient(45deg, #6b7c6b 25%, transparent 25%), linear-gradient(-45deg, #6b7c6b 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #6b7c6b 75%), linear-gradient(-45deg, transparent 75%, #6b7c6b 75%); background-size: 40px 40px; background-position: 0 0, 0 20px, 20px -20px, -20px 0px;"></div>
        </div>

        <!-- Content -->
        <div class="absolute inset-0 flex flex-col justify-end p-10 bg-gradient-to-t from-jaded-bg/90 via-jaded-bg/50 to-transparent">
          <div class="mb-6">
            <div class="w-12 h-12 rounded-full bg-muted-sage/20 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-muted-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-display text-3xl font-bold text-muted-sage mb-2">JADED DESIGN</h3>
            <p class="text-cream/50 text-sm">Digital experiences crafted with precision</p>
          </div>

          <ul class="space-y-2 text-sm text-cream/40 mb-8">
            <li>Branding & Identity</li>
            <li>Web Design & Development</li>
            <li>Motion Graphics</li>
            <li>Creative Direction</li>
          </ul>

          <div class="flex items-center gap-2 text-muted-sage group-hover:gap-4 transition-all">
            <span class="text-sm font-medium">Enter</span>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>

        <!-- Hover glow -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-t from-muted-sage/5 to-transparent pointer-events-none"></div>
      </a>

      <!-- TylahJadeArt -->
      <a
        href="/art"
        class="group relative overflow-hidden rounded-3xl aspect-[4/5] bg-art-surface border border-white/5 hover:border-dusty-pink/30 transition-all duration-500"
      >
        <!-- Background texture -->
        <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 400 400%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

        <!-- Content -->
        <div class="absolute inset-0 flex flex-col justify-end p-10 bg-gradient-to-t from-art-bg/90 via-art-bg/50 to-transparent">
          <div class="mb-6">
            <div class="w-12 h-12 rounded-full bg-dusty-pink/20 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-dusty-pink" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
              </svg>
            </div>
            <h3 class="font-display text-3xl font-bold text-dusty-pink mb-2">TYLAHJADEART</h3>
            <p class="text-cream/50 text-sm">Tactile creations touched by human hands</p>
          </div>

          <ul class="space-y-2 text-sm text-cream/40 mb-8">
            <li>Paintings & Murals</li>
            <li>Pottery & Ceramics</li>
            <li>Photography</li>
            <li>Mixed Media</li>
          </ul>

          <div class="flex items-center gap-2 text-dusty-pink group-hover:gap-4 transition-all">
            <span class="text-sm font-medium">Enter</span>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>

        <!-- Hover glow -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-t from-dusty-pink/5 to-transparent pointer-events-none"></div>
      </a>
    </div>
  </div>
</section>